{
	"name": "form-father",
	"version": "0.2.12",
	"description": "Form Father: Библиотека для обработки форм",
	"type": "module",
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"RESPONSE_API.md"
	],
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./FormFather.min.js": "./dist/FormFather.min.js"
	},
	"scripts": {
		"pack:dry-run": "npm_config_cache=/tmp/form-father-npm-cache npm pack --dry-run",
		"smoke:types": "node scripts/smoke-types.mjs"
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Poliklot/form-father"
	},
	"keywords": [
		"form",
		"vanila",
		"javascript",
		"typescript",
		"validation",
		"library"
	],
	"author": "Poliklot",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/poliklot/form-father/issues"
	},
	"sideEffects": false,
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"unpkg": "./dist/FormFather.min.js",
	"jsdelivr": "./dist/FormFather.min.js"
}
