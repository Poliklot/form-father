{
	"name": "form-father",
	"version": "0.8.2",
	"description": "Form Father: Библиотека для обработки форм",
	"type": "module",
	"main": "./dist/index.js",
	"module": "./dist/index.js",
	"types": "./dist/index.d.ts",
	"exports": {
		".": {
			"types": "./dist/index.d.ts",
			"import": "./dist/index.js",
			"default": "./dist/index.js"
		},
		"./FormFather.min.js": "./dist/FormFather.min.js"
	},
	"unpkg": "./dist/FormFather.min.js",
	"jsdelivr": "./dist/FormFather.min.js",
	"files": [
		"dist",
		"README.md",
		"LICENSE",
		"RESPONSE_API.md",
		"CHANGELOG.md",
		"docs",
		"demos"
	],
	"scripts": {
		"build": "npm run build:js && npm run build:types",
		"build:js": "rollup -c",
		"build:types": "tsc -p tsconfig.json --emitDeclarationOnly && rollup -c rollup.types.config.js",
		"watch": "rollup -c -w",
		"check": "npm run release:check",
		"release:check": "npm test -- --runInBand --watchman=false && npm run docs:check && npm run build && npm run smoke:package && npm run pack:dry-run",
		"docs:check": "node scripts/check-docs.mjs",
		"test": "jest --coverage",
		"prepublishOnly": "npm run release:check",
		"pack:dry-run": "npm_config_cache=/tmp/form-father-npm-cache npm pack --dry-run",
		"smoke:package": "node scripts/smoke-package.mjs",
		"demos": "BUILD_TARGET=demos npm run build && concurrently --kill-others \"vite\" \"npm run watch\""
	},
	"repository": {
		"type": "git",
		"url": "https://github.com/Poliklot/form-father"
	},
	"keywords": [
		"form",
		"vanila",
		"javascript",
		"typescript",
		"validation",
		"library"
	],
	"author": "Poliklot",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/Poliklot/form-father/issues"
	},
	"sideEffects": false,
	"devDependencies": {
		"@babel/preset-env": "^7.26.0",
		"@rollup/plugin-babel": "^7.1.0",
		"@rollup/plugin-commonjs": "^29.0.3",
		"@rollup/plugin-json": "^6.1.0",
		"@rollup/plugin-node-resolve": "^16.0.3",
		"@rollup/plugin-terser": "^1.0.0",
		"@types/jest": "^30.0.0",
		"@types/jsdom": "^21.1.7",
		"concurrently": "^9.0.1",
		"esbuild": "^0.28.1",
		"jest": "^30.0.5",
		"jest-environment-jsdom": "^30.0.5",
		"jsdom": "^29.1.1",
		"postcss-preset-env": "^11.3.1",
		"prettier-plugin-jsdoc": "^1.3.0",
		"rollup": "^4.24.3",
		"rollup-plugin-copy": "^3.5.0",
		"rollup-plugin-delete": "^2.1.0",
		"rollup-plugin-dts": "^6.1.1",
		"rollup-plugin-esbuild": "^6.2.1",
		"sass-embedded": "^1.80.5",
		"ts-jest": "^29.4.0",
		"ts-node": "^10.9.2",
		"typescript": "^6.0.3",
		"vite": "^8.0.16"
	},
	"overrides": {
		"js-yaml": "4.2.0"
	}
}
